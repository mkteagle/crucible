{
  "name": "crucible-ui",
  "version": "1.0.0",
  "description": "Headless, style-agnostic UI primitives for React — Dialog, Popover, DataGrid, MDX Editor & more",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.js",
      "require": "./dist/dialog.cjs"
    },
    "./popover": {
      "types": "./dist/popover.d.ts",
      "import": "./dist/popover.js",
      "require": "./dist/popover.cjs"
    },
    "./gridular": {
      "types": "./dist/gridular.d.ts",
      "import": "./dist/gridular.js",
      "require": "./dist/gridular.cjs"
    },
    "./gridular/styles": "./dist/gridular.css",
    "./mdx": {
      "types": "./dist/mdx.d.ts",
      "import": "./dist/mdx.js",
      "require": "./dist/mdx.cjs"
    },
    "./mdx/styles": "./dist/editor.css",
    "./lyric-ipsum": {
      "types": "./dist/lyric-ipsum.d.ts",
      "import": "./dist/lyric-ipsum.js",
      "require": "./dist/lyric-ipsum.cjs"
    },
    "./lyric-ipsum/api": {
      "types": "./dist/lyric-ipsum-api.d.ts",
      "import": "./dist/lyric-ipsum-api.js",
      "require": "./dist/lyric-ipsum-api.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && cp ../mdx-wysiwyg/src/styles/editor.css dist/editor.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-virtual": "^3.13.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.559.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "optionalDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
