{
  "name": "crucible",
  "version": "0.0.0",
  "private": true,
  "description": "Crucible — a public component library by mkteagle",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "typecheck": "pnpm -r run typecheck",
    "publish:all": "pnpm -r publish --access public",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@storybook/addon-controls": "^8.6.0",
    "@storybook/addon-docs": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
